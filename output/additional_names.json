    },
    {
      "name": "VRCInputManager",
      "rule": "Has nested enum with SafetyLevel field; contains Dict<string,T> static private fields where T is VRCInput",
      "source": "vrchat_dumper"
    },
    {
      "name": "VRCPlayer",
      "rule": "Has ReloadAvatarNetworkedRPC method",
      "source": "vrchat_dumper"
    },
    {
      "name": "VRCMotionState",
      "rule": "Has nested enum with Airborne field",
      "source": "vrchat_dumper"
    },
    {
      "name": "PedalOption",
      "rule": "Has nested enum with Default and Back fields",
      "source": "vrchat_dumper"
    },
    {
      "name": "ActionMenu",
      "rule": "Has nested enum with Summer field",
      "source": "vrchat_dumper"
    },
    {
      "name": "PlayerJoinEventsClass",
      "rule": "Has private OnPlayerJoined(1 param) + OnPlayerLeft(1 param) + DateTime field",
      "source": "vrchat_dumper"
    },
    {
      "name": "PortalInternal",
      "rule": "Has Method_Public_Void_ methods with xref string ' was at capacity, cannot enter.'",
      "source": "ReModCE"
    },
    {
      "name": "PageWorldInfo.SelectWorldInstance",
      "rule": "Has xref to string 'Make Home', starts with Method_Private_Void_, name length < 22",
      "source": "ReModCE"
    },
    {
      "name": "SelectedUserMenuQM.SetUser",
      "rule": "Method starts with Method_Private_Void_IUser_PDM_ and has XrefScan count >= 3",
      "source": "ReModCE"
    },
    {
      "name": "MenuController.SetupUserInfo",
      "rule": "Method starts with Method_Public_Void_APIUser_ and does NOT contain _PDM_",
      "source": "ReModCE"
    },
    {
      "name": "UiWorldInstanceList.OnContentButtonGenerated",
      "rule": "Method starts with Method_Protected_Virtual_Void_VRCUiContentButton_Object_",
      "source": "ReModCE"
    },
    {
      "name": "RiskyFunctions WorldCheck",
      "rule": "World is safe if: instance type <= FriendsOfGuests, name has no 'club'/'game', no blacklisted tags (author_tag_game/games/club, admin_game), no root GO named eVRCRiskFuncDisable/UniversalRiskyFuncDisable",
      "source": "ReModCE"
    },
    {
      "name": "RiskyFunctions WorldForceEnable",
      "rule": "Root GameObjects named eVRCRiskFuncEnable or UniversalRiskyFuncEnable force-enable risky functions",
      "source": "ReModCE"
    }
  ],
